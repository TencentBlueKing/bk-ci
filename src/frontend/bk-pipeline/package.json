{
  "name": "bkui-pipeline",
  "version": "1.0.0",
  "description": "devops pipeline",
  "type": "module",
  "main": "dist/bk-pipeline.cjs.js",
  "module": "dist/bk-pipeline.esm.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/bk-pipeline.min.js",
  "jsdelivr": "dist/bk-pipeline.min.js",
  "exports": {
    ".": {
      "import": "./dist/bk-pipeline.esm.js",
      "require": "./dist/bk-pipeline.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./vue2": {
      "import": "./dist/vue2/bk-pipeline.esm.js",
      "require": "./dist/vue2/bk-pipeline.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./vue3": {
      "import": "./dist/vue3/bk-pipeline.esm.js",
      "require": "./dist/vue3/bk-pipeline.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/bkui-pipeline.css": "./dist/vue3/bkui-pipeline.css",
    "./dist/bk-pipeline.css": "./dist/vue2/bk-pipeline.css"
  },
  "files": [
    "dist",
    "src",
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && pnpm --filter bkui-pipeline-vue2-build run build",
    "build:vue3": "vite build",
    "build:vue2": "pnpm --filter bkui-pipeline-vue2-build run build",
    "public": "pnpm run build",
    "public:master": "pnpm run build",
    "preview": "vite preview",
    "patch": "npm version patch && npm publish",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "lockiechen",
  "license": "MIT",
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vitejs/plugin-vue2": "^2.3.3",
    "eslint": "^8.56.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-vue": "^9.20.0",
    "sass": "^1.70.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "uuid": "~8.1.0",
    "vue-draggable-plus": "^0.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tencent/bk-ci.git"
  },
  "peerDependencies": {
    "vue": "^2.7.0 || ^3.0.0",
    "bkui-vue": "^2.0.1",
    "@tencent/bk-magic-vue": "2.5.10-beta.14"
  },
  "peerDependenciesMeta": {
    "bk-magic-vue": {
      "optional": true
    },
    "bkui-vue": {
      "optional": true
    }
  },
  "keywords": [
    "pipeline",
    "ci"
  ],
  "bugs": {
    "url": "https://github.com/Tencent/bk-ci/issues"
  },
  "homepage": "https://github.com/Tencent/bk-ci#readme"
}
