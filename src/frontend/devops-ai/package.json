{
  "name": "devops-ai",
  "version": "0.1.0",
  "main": "dist/devops-ai.umd.js",
  "module": "dist/devops-ai.common.js",
  "exports": {
    ".": {
      "import": "./dist/devops-ai.common.js",
      "require": "./dist/devops-ai.umd.js"
    },
    "./dist/devops-ai.css": "./dist/devops-ai.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "build:lib": "BUILD_TARGET=lib vue-cli-service build --target lib --name ci-ai src/index.ts",
    "public:master": "vue-cli-service build",
    "lint": "vue-cli-service lint"
  },
  "peerDependencies": {
    "bkui-vue": ">=2.0.0",
    "vue": "^3.2.0"
  },
  "dependencies": {
    "@blueking/chat-x": "0.0.28",
    "@microsoft/fetch-event-source": "^2.0.1",
    "bkui-vue": "2.0.2-beta.81",
    "core-js": "^3.8.3",
    "fetch-event-source": "1.0.0-alpha.2",
    "vue": "^3.2.13"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@babel/plugin-transform-class-static-block": "^7.28.6",
    "@babel/preset-typescript": "^7.28.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "typescript": "^6.0.2"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "rules": {
      "no-unused-vars": "off"
    },
    "overrides": [
      {
        "files": [
          "*.ts",
          "*.tsx"
        ],
        "rules": {
          "no-undef": "off"
        }
      }
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "nx": {
    "targets": {
      "inputs": [
        "{workspaceRoot}/locale/ai/*.json",
        "{workspaceRoot}/locale/index.js",
        "{projectRoot}"
      ],
      "public:master": {
        "outputs": [
          "{workspaceRoot}/frontend/ai"
        ]
      }
    }
  }
}
